{
  "name": "www.clausconrad.com",
  "type": "module",
  "version": "1.0.0",
  "private": true,
  "license": "MIT",
  "description": "Blog and digital garden of Claus Conrad",
  "scripts": {
    "dev": "astro dev",
    "ingest": "tsx scripts/ingest/index.ts",
    "favicons": "tsx scripts/favicons.ts",
    "prebuild": "npm run ingest && npm run favicons",
    "build": "astro build",
    "preview": "astro preview",
    "migrate-blog-slugs": "tsx scripts/migrate-blog-slugs.ts",
    "migrate-redirects": "tsx scripts/migrate-redirects.ts",
    "validate": "tsx scripts/validate.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "tsc --noEmit && prettier . --check",
    "format": "prettier . --write"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "dependencies": {
    "@astrojs/starlight": "^0.41.1",
    "astro": "^7.0.3",
    "force-graph": "^1.51.4",
    "github-slugger": "^2.0.0",
    "js-yaml": "^4.2.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.10.0",
    "prettier": "^3.4.0",
    "tsx": "^4.22.4",
    "typescript": "^5.7.0",
    "vitest": "^4.1.9"
  },
  "allowScripts": {
    "esbuild@0.28.1": true,
    "fsevents@2.3.3": true,
    "sharp@0.34.5": true
  }
}
