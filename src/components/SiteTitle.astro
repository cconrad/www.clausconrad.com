---
// Keep the owner's photo at the top of the site (§7). Served from the single
// /assets tree (passthrough, unhashed — §6.3), not Astro's hashed pipeline.
const { siteTitle } = Astro.locals.starlightRoute
---

<a href="/" class="site-title">
  <img
    src="/assets/images/sidebar_profile.png"
    alt=""
    width="36"
    height="36"
    class="site-title__photo"
  />
  <span class="site-title__text">{siteTitle}</span>
</a>

<style>
  .site-title {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    color: var(--sl-color-text-accent);
    font-size: var(--sl-text-h4);
    font-weight: 600;
    text-decoration: none;
    white-space: nowrap;
  }
  .site-title__photo {
    border-radius: 50%;
    object-fit: cover;
  }
</style>
