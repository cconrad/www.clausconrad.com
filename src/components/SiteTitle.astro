---
// Owner's photo + wordmark at the top of the site (§7). The wordmark is a fixed
// brand string (§5), shown in the regular text colour rather than the link
// accent. Photo is served from the single /assets tree (passthrough, unhashed —
// §6.3), not Astro's hashed pipeline.
---

<a href="/" class="site-title">
  <img
    src="/assets/images/sidebar_profile.png"
    alt=""
    width="36"
    height="36"
    class="site-title__photo"
  />
  <span class="site-title__text">{"{ claus.conrad }"}</span>
</a>

<style>
  .site-title {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    color: var(--sl-color-text);
    font-size: var(--sl-text-h4);
    font-weight: 600;
    text-decoration: none;
    white-space: nowrap;
  }
  .site-title__photo {
    border-radius: 50%;
    object-fit: cover;
  }
</style>
