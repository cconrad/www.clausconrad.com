---
import Default from '@astrojs/starlight/components/PageTitle.astro'

// On the home page, render the vault-maintained intro (§2) in place of the
// title. On content pages, render the default title plus a byline with
// Created/Updated dates (§13) and reading time / word count (§9.3).
const data = Astro.locals.starlightRoute.entry.data as {
  kind?: 'blog' | 'note' | 'page'
  created?: string
  updated?: string
  readingMinutes?: number
  words?: number
}

// §2: home-page intro Markdown, generated by ingest. Absent (e.g. `astro dev`
// before ingest) → fall back to the default title.
const isHome = Astro.url.pathname === '/'
const introMods = import.meta.glob('../data/homeIntro.gen.md', { eager: true })
const IntroEntry = Object.values(introMods)[0] as { Content?: unknown } | undefined
const Intro = isHome ? (IntroEntry?.Content as any) : undefined

function fmt(s?: string): string | null {
  if (!s) return null
  const d = new Date(s)
  if (Number.isNaN(d.getTime())) return null
  return d.toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
    timeZone: 'UTC',
  })
}

const isContent = data.kind === 'blog' || data.kind === 'note' || data.kind === 'page'
const created = fmt(data.created)
const updated = fmt(data.updated)
const showUpdated = updated && updated !== created

// §6: each section separated by " · ".
const bylineParts: string[] = []
if (created) bylineParts.push(`Created ${created}`)
if (showUpdated) bylineParts.push(`Updated ${updated}`)
if (data.readingMinutes) bylineParts.push(`${data.readingMinutes} min read`)
if (data.words) bylineParts.push(`${data.words} words`)
const showByline = isContent && bylineParts.length > 0
---

{
  Intro ? (
    <div class="sl-markdown-content home-intro">
      <Intro />
    </div>
  ) : (
    <>
      <Default />
      {showByline && <p class="page-byline">{bylineParts.join(' · ')}</p>}
    </>
  )
}

<style>
  .page-byline {
    margin-top: 0.4rem;
    color: var(--sl-color-gray-3);
    font-size: var(--sl-text-sm);
  }
</style>
